# ─── API ────────────────────────────────────────────────────────────────────
# Base URL for the real backend API (no trailing slash).
# Leave empty during the storage phase — the HTTP client scaffold uses '' as
# its default, which means requests will be relative to the dev server origin.
# Set to the full API origin (e.g. https://api.example.com) when the real
# backend is wired up (VITE_DATA_SOURCE=api phase).
VITE_API_BASE_URL=

# ─── Data source ────────────────────────────────────────────────────────────
# Controls which adapter the data-access layer uses.
#   storage  — current default: reads/writes via storage.js (localStorage +
#              Supabase KV). No real API calls are made.
#   api      — future phase: reads/writes via httpClient.js against
#              VITE_API_BASE_URL. Requires the real backend to be running.
VITE_DATA_SOURCE=storage

# Demo tools
# Default off for production-like runtime. Set to true only for local demos or
# e2e smoke tests that intentionally exercise the simulation panel.
VITE_ENABLE_DEMO_TOOLS=false
